                "name": "Authorization",
                "value": "Bearer {{ $env.KIEAI_API_KEY }}"
              }
            ]
          }
        },
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.1,
        "position": [450, 300],
        "name": "Suno API Call",
        "id": "sunu-api-call"
      },
      {
        "parameters": {
          "url": "https://videomusic.plamanco.com/api/api.php?action=webhook_n8n",
          "method": "POST",
          "body": {
            "event": "music_generated",
            "data": "={{ $json }}"
          },
          "headers": {}
        },
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.1,
        "position": [650, 300],
        "name": "Webhook Response",
        "id": "webhook-response"
      }
    ],
    "connections": {
      "Webhook Trigger": {
        "main": [[{"node": "Suno API Call", "type": "main", "index": 0}]]
      },
      "Suno API Call": {
        "main": [[{"node": "Webhook Response", "type": "main", "index": 0}]]
      }
    },
    "settings": {"executionOrder": "v1"}
  },
